{
  "manifest_version": 3,
  "name": "MR AI Stan Assistant",
  "version": "1.0.0",
  "description": "Chrome Extension connected to MR AI local backend engine.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
